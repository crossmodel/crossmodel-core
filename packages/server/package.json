{
  "name": "@crossmodel/server",
  "version": "0.7.1",
  "description": "CrossModel Server containing all server components (Language Server, GLSP Server, Model Server)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crossmodel/crossmodel-core.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "CrossBreeze",
    "email": "devops@crossbreeze.nl"
  },
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "bin": {
    "cross-model-cli": "./bin/cli"
  },
  "scripts": {
    "build": "yarn langium:generate && tsc -b tsconfig.json",
    "clean": "rimraf lib *.tsbuildinfo",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "lint": "eslint -c ../../configs/base.eslintrc.js --ext .ts,.tsx ./src",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "watch": "tsc -b tsconfig.json --watch"
  },
  "dependencies": {
    "@crossmodel/protocol": "0.7.0",
    "@eclipse-glsp/server": "2.4.0",
    "chalk": "~5.4.1",
    "chevrotain": "~11.0.3",
    "commander": "~14.0.0",
    "elkjs": "^0.10.0",
    "langium": "^3.5.0",
    "p-debounce": "^2.1.0",
    "prettier": "^3.1.0",
    "type-fest": "^4.18.2",
    "uuid": "~11.1.0",
    "vscode-jsonrpc": "8.2.0",
    "vscode-languageserver": "9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "cross-env": "~7.0.3",
    "jest": "^29.7.0",
    "langium-cli": "^3.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.5",
    "typescript": ">=4.9.3"
  }
}
